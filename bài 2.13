          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Mức GIẢM GIÁ đề xuất cho mặt hàng đặc biệt: 55.00%\n"
          ]
        },
        {
          "output_type": "display_data",
          "data": {
            "text/plain": [
